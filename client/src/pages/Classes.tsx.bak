                  <div style={{ flex: 1, marginBottom: "2rem" }}>
                    {tier.features.map((f, j) => (
                      <div key={j} style={{ display: "flex", alignItems: "flex-start", gap: "0.75rem", marginBottom: "0.75rem" }}>
                        <span style={{ color: "#C9A96E", flexShrink: 0, marginTop: "0.1rem", fontSize: "0.8rem" }}>✓</span>
                        <span style={{ fontFamily: "'DM Sans'", fontSize: "0.85rem", color: "rgba(239,239,239,0.7)", lineHeight: 1.5 }}>{f}</span>
                      </div>
                    ))}
                    {tier.notIncluded.map((f, j) => (
                      <div key={j} style={{ display: "flex", alignItems: "flex-start", gap: "0.75rem", marginBottom: "0.75rem", opacity: 0.35 }}>
                        <span style={{ fontFamily: "'DM Mono'", fontSize: "0.7rem", color: "rgba(239,239,239,0.4)", flexShrink: 0, marginTop: "0.1rem" }}>&#x2715;</span>
                        <span style={{ fontFamily: "'DM Sans'", fontSize: "0.85rem", color: "rgba(239,239,239,0.4)", lineHeight: 1.5, textDecoration: "line-through" }}>{f}</span>
                      </div>
                    ))}
                  </div>
                  <a href={tier.href}
                    target={tier.href.startsWith("http") ? "_blank" : "_self"}
                    rel="noopener noreferrer"
                    className={tier.highlight ? "btn-primary" : "btn-outline"}
                    style={{ justifyContent: "center", textAlign: "center", display: "flex", alignItems: "center", gap: "0.5rem" }}>
                    {tier.cta} <ArrowRight size={13} />
                  </a>
                </div>
              </Reveal>
            ))}
          </div>
        </div>
      </section>

      {/* BOTTOM CTA */}
      <section style={{ background: "#080808" }}>
        <div className="container" style={{ paddingTop: "5rem", paddingBottom: "5rem", textAlign: "center" }}>
          <Reveal>
            <div className="rule" style={{ justifyContent: "center" }}><span className="label-mono">Start Today</span></div>
            <h2 className="display-serif" style={{ fontSize: "clamp(2rem, 4vw, 3rem)", marginBottom: "1rem" }}>
              The free class is the{" "}
              <span className="display-serif-italic text-gold">best place to start.</span>
            </h2>
            <p style={{ fontSize: "1rem", lineHeight: 1.75, color: "rgba(239,239,239,0.5)", maxWidth: "480px", margin: "0 auto 2.5rem", fontWeight: 300 }}>
              No credit card. No trial period. 6 chapters, 15 lessons, and a framework that will change how you think about health.
            </p>
            <div style={{ display: "flex", gap: "1rem", justifyContent: "center", flexWrap: "wrap" }}>
              <a href="https://whatismetfix.metfixclass.com/" target="_blank" rel="noopener noreferrer" className="btn-primary" style={{ padding: "1rem 2.5rem" }}>
                Take the Free Class <ArrowRight size={15} />
              </a>
              <Link href="/become-an-affiliate" className="btn-outline" style={{ padding: "1rem 2rem" }}>
                Become an Affiliate
              </Link>
            </div>
          </Reveal>
        </div>
      </section>

      {/* FOOTER */}
      <footer style={{ background: "#080808", borderTop: "1px solid rgba(255,255,255,0.06)", paddingTop: "2.5rem", paddingBottom: "2rem" }}>
        <div className="container">
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", flexWrap: "wrap", gap: "1rem" }}>
            <div>
              <div style={{ fontFamily: "'DM Sans'", fontWeight: 800, fontSize: "1rem", letterSpacing: "0.15em", color: "#EFEFEF", textTransform: "uppercase" }}>MetFix</div>
              <div style={{ fontFamily: "'DM Mono'", fontSize: "0.5rem", letterSpacing: "0.18em", color: "#C9A96E", textTransform: "uppercase" }}>The Metabolic Fix</div>
            </div>
            <div style={{ display: "flex", gap: "2rem", flexWrap: "wrap" }}>
              <Link href="/" style={{ fontFamily: "'DM Sans'", fontSize: "0.8rem", color: "rgba(239,239,239,0.4)", textDecoration: "none" }}>← Home</Link>
              <Link href="/affiliate-seminars" style={{ fontFamily: "'DM Sans'", fontSize: "0.8rem", color: "rgba(239,239,239,0.4)", textDecoration: "none" }}>Foundations Seminar</Link>
              <Link href="/become-an-affiliate" style={{ fontFamily: "'DM Sans'", fontSize: "0.8rem", color: "rgba(239,239,239,0.4)", textDecoration: "none" }}>Become an Affiliate</Link>
            </div>
            <div style={{ fontFamily: "'DM Mono'", fontSize: "0.5rem", letterSpacing: "0.1em", color: "rgba(239,239,239,0.2)", textTransform: "uppercase" }}>© 2025 MetFix. All rights reserved.</div>
          </div>
        </div>
      </footer>
    </div>
  );
}
